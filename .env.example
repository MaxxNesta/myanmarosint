# PostgreSQL (Neon) — copy to .env.local and fill in your values
DATABASE_URL="postgresql://your_user:your_password@your_host.neon.tech/neondb?sslmode=require"

# Anthropic — required for the OSINT processing pipeline
# Get your key at console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-your_key_here"

# Mapbox — get a free token at mapbox.com/account/access-tokens
NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ1IjoiWU9VUl9VU0VSTkFNRSIsImEiOiJZT1VSX1RPS0VOIn0.XXXXX"

# ACLED conflict data — register free at acleddata.com
ACLED_API_KEY="your_acled_api_key_here"
ACLED_EMAIL="your@email.com"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Parent Tatmadaw static site URL (shown as "← Tatmadaw" in the platform navbar).
# Use http://127.0.0.1:5500 for VS Code Live Server.
# Use http://localhost:5500 for some configs.
# Leave blank to omit the back-link.
NEXT_PUBLIC_TATMADAW_URL="http://127.0.0.1:5500"

# Vercel Cron secret (set this in Vercel dashboard too)
CRON_SECRET="generate_a_random_secret_here"
